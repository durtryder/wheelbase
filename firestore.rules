rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Vehicles: owner can read/write their own; public vehicles readable by anyone.
    match /vehicles/{vehicleId} {

      // Read a single vehicle OR list vehicles you own / public / unlisted.
      // 'unlisted' is "accessible via direct link but not listed in the
      // feed" — that distinction lives in queries (Feed filters to
      // visibility == 'public'), not in rules.
      allow read: if resource.data.visibility == 'public'
                  || resource.data.visibility == 'unlisted'
                  || (request.auth != null
                      && request.auth.uid == resource.data.ownerId);

      // Create: must be signed in, and the document's ownerId must be your own UID.
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.ownerId
                    && request.resource.data.keys().hasAll(['ownerId', 'year', 'make', 'model'])
                    && request.resource.data.ownerId is string
                    && request.resource.data.year is number
                    && request.resource.data.make is string
                    && request.resource.data.model is string;

      // Update / delete: must own the existing document.
      // Additional check: if `ownerId` is in the payload, it can't change.
      allow update: if request.auth != null
                    && request.auth.uid == resource.data.ownerId
                    && (!('ownerId' in request.resource.data.keys())
                        || request.resource.data.ownerId == resource.data.ownerId);

      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.ownerId;
    }

    // Media items: metadata rows that point at Storage objects. Public read
    // (metadata carries a download URL which is already shareable by anyone
    // who's seen the vehicle), owner-only write.
    match /media/{mediaId} {
      allow read: if true;

      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.ownerId
                    && request.resource.data.keys().hasAll(['vehicleId', 'ownerId', 'kind', 'storagePath']);

      allow update, delete: if request.auth != null
                            && request.auth.uid == resource.data.ownerId;
    }

    // Vehicle documents — PDFs, scanned invoices, service records, etc.
    match /documents/{documentId} {
      allow read: if true;

      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.ownerId
                    && request.resource.data.keys().hasAll(['vehicleId', 'ownerId', 'title', 'storagePath', 'downloadUrl']);

      allow update, delete: if request.auth != null
                            && request.auth.uid == resource.data.ownerId;
    }

    // User profile docs — public read (so /u/{uid} can show social links),
    // self-write only. Doc ID is the user's UID.
    match /users/{uid} {
      allow read: if true;
      allow create, update: if request.auth != null && request.auth.uid == uid;
      allow delete: if false;
    }

    // Default deny for anything else.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
