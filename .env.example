# Firebase web config — copy this file to `.env` and fill in values from the
# Firebase Console -> Project settings -> "Your apps" -> Web app.
# Expo exposes any variable prefixed with EXPO_PUBLIC_ to the client bundle.

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Optional — only present if Google Analytics is enabled on the Firebase project
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Optional — shared password that gates the site while in private preview.
# Leave empty to disable the gate entirely (useful for dev / production).
EXPO_PUBLIC_ACCESS_PASSWORD=
